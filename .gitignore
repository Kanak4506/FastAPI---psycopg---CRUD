.coverage
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.log

# Type Checking
.mypy_cache/
.pyre/

# FastAPI / Database specific
*.db
*.sqlite3

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
